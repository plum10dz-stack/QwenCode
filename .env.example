# StockOS — environment variables
# Copy this file to .env and fill in your values.
#
# Priority (first match wins):
#   1. VITE_SUPABASE_URL set  →  SupabaseStore (edge functions + Realtime)
#   2. VITE_API_URL set       →  ServerStore   (custom REST + WebSocket)
#   3. Neither                →  IndexedDB only (fully offline)

# ── Supabase (recommended) ─────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Custom REST backend (optional alternative) ──────────────────────────────
VITE_API_URL=
VITE_WS_URL=
